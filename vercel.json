{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/"
    }
  ],
  "functions": {
    "api/[...route].js": {
      "runtime": "nodejs20.x"
    }
  },
  "env": {
    "VITE_API_BASE_URL": "@api_base_url"
  }
}