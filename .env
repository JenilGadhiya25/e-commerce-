# MongoDB (required to persist data in MongoDB Compass)
# Example (local):
# MONGODB_URI=mongodb://127.0.0.1:27017
# MONGODB_DB=ark_packaging

# API server
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=5175
API_ALLOWED_ORIGIN=http://localhost:5173
API_ALLOWED_ORIGIN=https://e-commerce-three-red-13.vercel.app/

# Frontend API base URL (for development)
VITE_API_BASE_URL=http://localhost:5175

# Optional: protect admin API actions (products/orders)
# If set, admin actions must include header: x-admin-key: <value>
# API_ADMIN_KEY=change-me

